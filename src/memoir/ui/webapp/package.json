{
  "name": "memoir-webapp",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "Memoir web UI (v2) — Vite + React + TypeScript frontend bundled into the memoir-ai Python wheel.",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
